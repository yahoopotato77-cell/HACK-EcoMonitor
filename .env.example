# ============================================
# EcoMonitor Environment Variables
# ============================================
# Copy this file to .env and fill in your values.
# For Vercel: add these in Project Settings → Environment Variables.
# Vite requires the VITE_ prefix for client-side access.

# --- Backend API ---
# The Python Flask backend handles all Gemini AI calls server-side.
VITE_BACKEND_URL=http://localhost:5000

# --- Gemini AI (used by backend only, never exposed to browser) ---
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash
GEMINI_MODEL_LITE=gemini-2.0-flash-lite

# --- Flask Backend Settings ---
FLASK_ENV=development
FLASK_PORT=5000
CACHE_TTL=1800
CLIMATE_CACHE_TTL=86400
MAX_GEMINI_RPM=10

# --- Supabase ---
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# --- n8n Webhooks (optional) ---
VITE_N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/eco-monitor-alerts
VITE_N8N_ENABLED=true

# --- App Settings (optional, defaults shown) ---
# VITE_REFRESH_INTERVAL=30000
# VITE_ALERT_THRESHOLD_AQI=150
# VITE_ALERT_THRESHOLD_TEMP=40
# VITE_ALERT_THRESHOLD_WATER_PH=6.5
# VITE_ANOMALY_SENSITIVITY=0.8
# VITE_MAX_HISTORICAL_POINTS=50
